{
  "name": "vault404",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript SDK for vault404 - the collective AI coding agent brain",
  "author": "GlobalLayer",
  "license": "MIT",
  "keywords": [
    "ai",
    "coding",
    "agent",
    "knowledge-base",
    "error-tracking",
    "solutions",
    "patterns",
    "decisions",
    "mcp",
    "openai",
    "llm",
    "vault404"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/globallayer/vault404"
  },
  "homepage": "https://vault404.dev",
  "bugs": {
    "url": "https://github.com/globallayer/vault404/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^6.0.2",
    "vitest": "^1.2.0"
  }
}
