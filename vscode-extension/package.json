{
  "name": "vault404",
  "displayName": "404vault - AI Coding Agent Brain",
  "description": "Collective AI coding agent memory. Log errors, find solutions, and verify fixes from VS Code.",
  "version": "0.1.0",
  "publisher": "globallayer",
  "license": "FSL-1.1-Apache-2.0",
  "icon": "images/icon.svg",
  "repository": {
    "type": "git",
    "url": "https://github.com/globallayer/404vault"
  },
  "bugs": {
    "url": "https://github.com/globallayer/404vault/issues"
  },
  "homepage": "https://github.com/globallayer/404vault#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "coding",
    "errors",
    "solutions",
    "memory",
    "collective",
    "agent",
    "404vault"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vault404.logErrorFix",
        "title": "404vault: Log Error & Solution"
      },
      {
        "command": "vault404.findSolution",
        "title": "404vault: Find Solution for Error"
      },
      {
        "command": "vault404.findSolutionFromSelection",
        "title": "404vault: Find Solution for Selected Text"
      },
      {
        "command": "vault404.verifySolution",
        "title": "404vault: Verify Solution Worked"
      },
      {
        "command": "vault404.logDecision",
        "title": "404vault: Log Architectural Decision"
      },
      {
        "command": "vault404.logPattern",
        "title": "404vault: Log Reusable Pattern"
      },
      {
        "command": "vault404.showStats",
        "title": "404vault: Show Knowledge Base Stats"
      },
      {
        "command": "vault404.refreshStats",
        "title": "404vault: Refresh Stats"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vault404.findSolutionFromSelection",
          "when": "editorHasSelection",
          "group": "vault404@1"
        },
        {
          "command": "vault404.logErrorFix",
          "when": "editorHasSelection",
          "group": "vault404@2"
        }
      ]
    },
    "configuration": {
      "title": "404vault",
      "properties": {
        "vault404.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python executable (for vault404 CLI)"
        },
        "vault404.enableStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show 404vault stats in the status bar"
        },
        "vault404.autoQueryOnError": {
          "type": "boolean",
          "default": true,
          "description": "Automatically query community brain when errors are detected in Problems panel"
        },
        "vault404.defaultLanguage": {
          "type": "string",
          "default": "",
          "description": "Default language context for queries (auto-detected if empty)"
        },
        "vault404.defaultFramework": {
          "type": "string",
          "default": "",
          "description": "Default framework context for queries"
        },
        "vault404.communityEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable community brain search (requires VAULT404_COMMUNITY=true)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
